# lab/profiles/adversarial-positive.env — weird-but-VALID inputs.
#
# This is the POSITIVE adversarial profile: the inputs deliberately
# trip up implicit assumptions in configure_share, do_domain_join, and
# the firewall step, but every value is a configuration the appliance
# should ACCEPT and apply successfully. Scenarios run with this profile
# expect rc=0.
#
# The corresponding NEGATIVE profile is adversarial-collision.env —
# AD-colliding force-user names that configure_share REFUSES with rc=9.
# The negative path is exercised by lab/scenarios/collision-refused.sh,
# never by frontend-share / backend-mount / multi-share. Keep them
# split so a passing run for one profile is unambiguous.
#
# What each adversarial swap traps for:
#
#   SC_FORCE_USER="tubelaser" / "millhand"
#     Shop-floor-flavor names that DO NOT exist in BUILTIN or in any
#     conventional AD lab. These exercise the username-shape force-user
#     contract (Samba writes `force user = tubelaser` and resolves it
#     via getpwnam() through NSS files-first ordering) under realistic
#     non-trivial names. AD-colliding names like Administrator and
#     Guest are intentionally NOT here; they belong in
#     adversarial-collision.env where we expect rc=9 instead.
#
#   SC_GROUP="LAB\\Administrators" / "LAB\\Users"
#     SINGLE-WORD AD groups. The historic Samba 4.22 default-domain
#     bug fired specifically on single-word groups: the @"DOMAIN\Group"
#     form silently failed to match while multi-word groups happened to
#     work. The SID-based valid_users path resolves both shapes
#     correctly. Re-introducing @"DOMAIN\Group" form would pass with
#     the default profile and fail here.
#
#   SC_SHARE_NAME="Old.Files\$"
#     A share name with BOTH a $-suffix AND an embedded dot. Exercises
#     share_safe_name's full sanitization (translates to "Old_Files_"
#     for fstab paths, .creds-Old_Files_, /var/lib/smbproxy/shares/
#     Old_Files_.env) while keeping the literal name "Old.Files$" in
#     SHARE_NAME and in the smb.conf section header. Validated against
#     share_name_validate (single-trailing-$ exempted).
#
# For multi-share, both shares get adversarial swaps and use distinct
# single-word AD groups + distinct non-AD-colliding force-users to
# also exercise the "two trap-bearing shares are independent" property.
#
# Usage:
#   lab/run-scenario.sh frontend-share --profile adversarial-positive
#   lab/run-scenario.sh multi-share    --profile adversarial-positive
#
# Prerequisites in the lab.test forest:
#   - LAB\Administrators and LAB\Users groups exist (built-in, always do).
#   - 'tubelaser' and 'millhand' do NOT exist as AD accounts (they are
#     deliberately chosen so that wbinfo --name-to-sid returns nothing,
#     i.e. configure_share does NOT trip the rc=9 collision refusal).

# --- single-share (frontend-share, backend-mount, end-to-end) ---
export SC_SHARE_NAME='Old.Files$'
export SC_FORCE_USER='tubelaser'
export SC_GROUP='LAB\Administrators'

# --- multi-share ---
# Share A: shop-floor force-user + single-word AD group.
export SC_SHARE_A='Old.Files$'
export SC_FORCE_USER_A='tubelaser'
export SC_GROUP_A='LAB\Administrators'

# Share B: a different shop-floor force-user + a different single-word
# AD group. The two shares MUST resolve to distinct local UIDs and
# distinct SIDs — that independence cross-check is the multi-share
# regression bar.
export SC_SHARE_B='Drawings$'
export SC_FORCE_USER_B='millhand'
export SC_GROUP_B='LAB\Users'

# Backend identity is unchanged from the default — the backend
# account on the legacy server is what it is, and we don't want to
# test against an account that doesn't exist there.
