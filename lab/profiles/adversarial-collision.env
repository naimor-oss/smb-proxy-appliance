# lab/profiles/adversarial-collision.env — NEGATIVE force-user collision.
#
# Profile companion to adversarial-positive.env. The chosen
# SC_FORCE_USER deliberately collides with a BUILTIN AD account
# (Administrator) so configure_share's wbinfo --name-to-sid pre-check
# trips and the share configuration is REFUSED with rc=9.
#
# The single scenario that consumes this profile is
# lab/scenarios/collision-refused.sh, which expects:
#   - rc=9 from the configure attempt
#   - NO new creds file at /etc/samba/.creds-<safe>
#   - NO new fstab cifs line for the share's mount point
#   - NO [SHARE_NAME] section in smb.conf
#   - NO state file at /var/lib/smbproxy/shares/<safe>.env
#   - NO new /etc/passwd entry for the colliding name (the wbinfo
#     check fires before useradd, so the local account stays absent —
#     unless one already existed on the proxy from an earlier run, in
#     which case the scenario asserts no DELTA across the attempt).
#
# Do NOT run frontend-share / backend-mount / multi-share with this
# profile — those expect rc=0 and would all fail with this input by
# design.
#
# Usage:
#   lab/run-scenario.sh collision-refused --profile adversarial-collision

# Use a deliberately mundane share name + group; the test target is
# the force-user collision, and unrelated novelty in the share name
# would just dilute the signal if the scenario's verify mis-attributes
# a failure.
export SC_SHARE_NAME='CollisionTest'
export SC_FORCE_USER='Administrator'
export SC_GROUP='LAB\Administrators'
