# lab/profiles/adversarial.env — deliberately trap-laden inputs.
#
# The scenarios' built-in defaults are *cooperative*: pfuser, ProfitFab,
# "LAB\Domain Users". Cooperative inputs let several real bugs hide for
# weeks (see commits d480a7c, 17b51ab, e3db1b0 — all surfaced only when
# the user tested in production with adversarial-shaped names). This
# profile swaps in inputs that fight the implicit assumptions in
# configure_share, do_domain_join, and the firewall step.
#
# What each swap traps for:
#
#   SC_FORCE_USER="Administrator"
#     A name guaranteed to also exist as an AD account in any AD forest
#     (BUILTIN\Administrator). Triggers the default-domain ambiguity
#     defense in configure_share: `id Administrator` would resolve to
#     the AD account; the raw /etc/passwd grep correctly skips that
#     and creates a local entry; the WARN about colliding names should
#     fire in the configure log; the resulting smb.conf force user UID
#     must match /etc/passwd, NOT the AD UID. If a future refactor
#     reverts to `id NAME`, this profile fails loudly.
#
#   SC_GROUP="LAB\\Administrators"
#     A SINGLE-WORD AD group. The historic Samba 4.22 default-domain
#     bug fired specifically on single-word groups: the @"DOMAIN\Group"
#     form silently failed to match while multi-word groups happened to
#     work. The SID-based valid_users path resolves both shapes
#     correctly. Re-introducing @"DOMAIN\Group" form would pass with
#     the default profile and fail here.
#
#   SC_SHARE_NAME="Old.Files\$"
#     A share name with BOTH a $-suffix AND an embedded dot. Exercises
#     share_safe_name's full sanitization (translates to "Old_Files_"
#     for fstab paths, .creds-Old_Files_, /var/lib/smbproxy/shares/
#     Old_Files_.env) while keeping the literal name "Old.Files$" in
#     SHARE_NAME and in the smb.conf section header.
#
# For multi-share, both shares get adversarial swaps and use distinct
# single-word AD groups + distinct AD-colliding force-users to also
# exercise the "two trap-bearing shares are independent" property.
#
# Usage:
#   lab/run-scenario.sh frontend-share --profile adversarial
#   lab/run-scenario.sh multi-share    --profile adversarial
#
# Prerequisites in the lab.test forest:
#   - BUILTIN\Administrator and BUILTIN\Guest user accounts exist (always do).
#   - LAB\Administrators and LAB\Users groups exist (built-in, always do).
# No special AD setup is needed beyond the standard lab AD DC.

# --- single-share (frontend-share, backend-mount, end-to-end) ---
export SC_SHARE_NAME='Old.Files$'
export SC_FORCE_USER='Administrator'
export SC_GROUP='LAB\Administrators'

# --- multi-share ---
# Share A: AD-colliding force-user + single-word AD group.
export SC_SHARE_A='Old.Files$'
export SC_FORCE_USER_A='Administrator'
export SC_GROUP_A='LAB\Administrators'

# Share B: a different AD-colliding force-user + a different single-word
# AD group. The two shares MUST resolve to distinct local UIDs and
# distinct SIDs — that independence cross-check is the multi-share
# regression bar.
export SC_SHARE_B='Drawings$'
export SC_FORCE_USER_B='Guest'
export SC_GROUP_B='LAB\Users'

# Backend identity is unchanged from the default — the backend account
# on WS2008 is what it is, and we don't want to test against an account
# that doesn't exist on the legacy server.
