# Environment for running smb-proxy-appliance scenarios through
# ../lab-kit/bin/run-scenario.sh. Paths here are resolved relative to the
# current working directory at invocation time; lab/run-scenario.sh (the
# wrapper in this directory) cd's into the proxy repo root before sourcing.

LAB_NAME=smb-proxy
LAB_RESULTS_DIR=test-results

# Hyper-V target.
LAB_HV_HOST=server
LAB_HV_USER=nmadmin

# VM under test. The proxy lab uses 10.10.10.30 by default; the matching
# dnsmasq reservation in lab-router is described in docs/SETUP.md (it is
# NOT auto-created — operator must add it once before the first build).
LAB_VM_NAME=smbproxy-1
LAB_VM_IP=10.10.10.30
LAB_VM_USER=debadmin
LAB_GOLDEN_CHECKPOINT=golden-image

# Host share for staging Hyper-V helper scripts. Mac-visible vs.
# host-visible paths.
LAB_STAGE_DIR=/Volumes/ISO/lab-scripts
LAB_HOST_STAGE_DIR='D:\ISO\lab-scripts'

# Helper scripts from this repo plus lab-kit (Revert-TestVM.ps1) and
# lab-router (New-LabRouter.ps1). The proxy does not stand up its own
# WS2025 DC — it joins the one the samba-addc-appliance sibling already
# uses, so we DO NOT pull WS2025 helpers from there.
LAB_STAGE_SOURCES="lab/hyperv/*.ps1 ../lab-kit/hypervisors/hyperv/*.ps1 ../lab-router/hypervisors/hyperv/*.ps1"

# Appliance scripts scp'd to /tmp on the proxy VM before each run.
LAB_PUSH_FILES="prepare-image.sh smbproxy-sconfig.sh"
LAB_REMOTE_PUSH_DIR=/tmp

# After scp, install smbproxy-sconfig so scenarios can invoke it directly.
LAB_POST_PUSH_CMD='sudo install -m 0755 /tmp/smbproxy-sconfig.sh /usr/local/sbin/smbproxy-sconfig'
