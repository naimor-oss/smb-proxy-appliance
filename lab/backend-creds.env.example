# Backend credentials for the WS2008 SP2 share.
#
# Copy this file to lab/backend-creds.env (untracked — gitignored by
# the *creds* glob in .gitignore) and fill in the real password. The
# original credential is documented in docs/sketch-smb1-smb3-proxy.sh
# for reference.
#
# lab/run-scenario.sh sources lab/backend-creds.env automatically (or
# whatever path you pass with --backend-creds FILE) before invoking the
# scenario, so SC_BACKEND_PASS lands in the scenario's environment.
#
# Only SC_BACKEND_PASS is required; the other SC_BACKEND_* values
# already default to the production WS2008 coordinates inside the
# backend-mount / frontend-share / end-to-end scenarios.

SC_BACKEND_PASS='replace-me-with-the-real-pfuser-password'

# Optional overrides (uncomment if your backend differs from the
# defaults baked into the scenarios):
# SC_BACKEND_IP='172.29.137.1'
# SC_BACKEND_SHARE='ProfitFab$'
# SC_BACKEND_USER='pfuser'
# SC_BACKEND_DOMAIN='LEGACY'
# SC_BACKEND_MOUNT='/mnt/profitfab'
# SC_FORCE_USER='pfuser'
